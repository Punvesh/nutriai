# Copy to .env and fill values.
# Optional: enables AI-generated guidance in addition to the rule-based nutrition map.
ADVISOR_API_KEY=YOUR_API_KEY_HERE
ADVISOR_MODEL=gemini-1.5-flash

# Backwards-compatible env var names (supported by the code, but prefer ADVISOR_*):
# GEMINI_API_KEY=YOUR_API_KEY_HERE
# GEMINI_MODEL=gemini-1.5-flash

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

